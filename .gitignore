# =========================
# Python & Environments
# =========================
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.Python

# =========================
# Secrets & Credentials
# =========================
.env
*.env
# (Note: .env.example should NOT be ignored, which is why it's not here)

# =========================
# Data & Models (Safety Net)
# =========================
# DVC creates its own .gitignore files inside these folders, 
# but this is a secondary safety net to ensure heavy files never leak.
data/raw/*.csv
models/*.pt
models/*.pth

# =========================
# MLOps (MLflow & DVC)
# =========================
# Ignore local experiment tracking databases and local DVC configs
mlruns/
mlflow.db
.dvc/config.local

# =========================
# Testing
# =========================
.pytest_cache/
.coverage
htmlcov/

# =========================
# OS & IDE
# =========================
.DS_Store
.vscode/
.idea/