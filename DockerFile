# 1. Use an official, lightweight Python base image
FROM python:3.10-slim

# 2. Set the working directory inside the container
WORKDIR /app

# 3. Copy the requirements file first (this leverages Docker layer caching to speed up future builds)
COPY requirements.txt .

# 4. Install the Python dependencies
# --no-cache-dir keeps the final image size smaller by not saving the downloaded pip packages
RUN pip install --no-cache-dir -r requirements.txt

# 5. Copy the rest of your project files (src, api, models) into the container
COPY . .

# 6. Expose the port that FastAPI will run on
EXPOSE 8000

# 7. The command to start the server
# Note: We bind to 0.0.0.0 so the server is accessible outside the Docker container
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]